# =============================================================================
# Dirtbike Pipeline - .gitignore
# =============================================================================

# 真实配置（含 API key，绝对不能提交）
.env

# 翻译断点续传缓存（运行时生成，无需跟踪）
.translate_cache.json

# 词汇表由运行时自动维护，本地覆盖不应提交到公共仓库
# glossary.json  # 如果你想共享术语表，注释掉这行

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# 虚拟环境
venv/
.venv/
env/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# 编辑器
.vscode/
.idea/
*.swp
*.swo
*~

# 日志
*.log
logs/

# 临时文件
/tmp/
*.tmp
