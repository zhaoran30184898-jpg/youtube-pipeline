# Dirtbike Pipeline - 环境变量配置示例
# 复制此文件为 .env，填入你的实际 API Key
# cp .env.example .env

# =============================================================================
# 翻译后端选择
# 可选值: lemon | deepseek | google | claude | openclaw
# lemon   = Moonshot (kimi) API，默认推荐
# deepseek = DeepSeek-V3，中文质量好，价格低
# google  = 免费但质量一般，无需 API key
# =============================================================================
DIRTBIKE_MODEL_BACKEND=lemon

# =============================================================================
# LemonAPI / Moonshot 配置（DIRTBIKE_MODEL_BACKEND=lemon 时使用）
# =============================================================================
DIRTBIKE_LEMON_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DIRTBIKE_LEMON_API_BASE=https://api.moonshot.cn/v1
DIRTBIKE_LEMON_MODEL=moonshot-v1-128k

# =============================================================================
# DeepSeek 配置（DIRTBIKE_MODEL_BACKEND=deepseek 时使用）
# =============================================================================
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# =============================================================================
# Meta（标题/简介）生成后端，可与翻译后端不同
# 可选值: lemon | deepseek | google
# =============================================================================
DIRTBIKE_META_BACKEND=lemon

# =============================================================================
# 限流与重试控制
# =============================================================================
# 每个 batch 请求之间的等待时间（秒），防止 429 Too Many Requests
DIRTBIKE_TRANSLATION_DELAY=2.0

# 每次 API 调用翻译的字幕条数
DIRTBIKE_BATCH_SIZE=50

# 最大重试次数（429 时指数退避重试）
DIRTBIKE_MAX_RETRIES=3

# 指数退避基础延迟（秒），实际延迟 = BASE * 2^attempt
DIRTBIKE_RETRY_BASE_DELAY=2.0

# =============================================================================
# Pipeline Feature Flags
# 设为 0 可跳过对应步骤（加速调试）
# =============================================================================
DIRTBIKE_ASR_CORRECTION=1       # ASR 纠错（第3步）
DIRTBIKE_QUALITY_CHECK=1        # 质量验证（第5步）
DIRTBIKE_WHISPER_ADVANCED=1     # Whisper 高级模式

# =============================================================================
# OpenClaw Agent（DIRTBIKE_MODEL_BACKEND=openclaw 时使用）
# =============================================================================
DIRTBIKE_OPENCLAW_AGENT=main
